                r = (interest_rate / 100) / 12
                monthly = loan_amount * r / (1 - (1 + r) ** -n)
            else:
            # 0% interest is just the loan divided by months
                monthly = loan_amount / n
        
            total_repaid = monthly * n
        
            st.metric("Monthly repayment", f"R {monthly:,.0f}")
